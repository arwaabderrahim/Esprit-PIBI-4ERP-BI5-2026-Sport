	column 'Active Status' =
			
			VAR PlayerID = dim_player_ofc[Id_Player]
			VAR MatchCount =
			    CALCULATE(
			        COUNTROWS(fact_performance),
			        FILTER(
			            dim_team_ofc,
			            dim_team_ofc[Id_Player_1] = PlayerID
			            || dim_team_ofc[Id_Player_2]= PlayerID
			        )
			    )
			RETURN
			    IF(MatchCount > 0, "Active", "Inactive")
		lineageTag: 813dcd6e-06d3-4c7b-b4cc-75eb94c04cd2
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Is Active' =
			
			IF(dim_player_ofc[Active Status]= "Active", 1, 0)
		formatString: 0
		lineageTag: 9ec11971-4b6d-43f7-b3b3-77f6be562a21
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

