table fact_equipement
	lineageTag: a77e36be-5927-4ecb-b463-174d2ed7336c

	measure Nb_Marques = DISTINCTCOUNT(dim_vendor[vendor])
		formatString: 0
		lineageTag: 1bc0653f-f0d4-4244-b109-d64082ca4bec

	measure Nb_Types = DISTINCTCOUNT(dim_padel_info[racket_type])
		formatString: 0
		lineageTag: d0095455-bbda-4d3b-9226-538e88aa97dc

	measure Nb_Equipements = COUNTROWS(fact_equipement)
		formatString: 0
		lineageTag: 33d8e5de-b8c1-4a6f-a63b-f7fdf138f98c

	measure 'Sponsored Players' =
			
			DISTINCTCOUNT(fact_equipement[Id_player])
		formatString: 0
		lineageTag: 63413eed-246f-46be-a932-67f89bbd1b01

	measure Prix_Moyen = AVERAGE(fact_equipement[price])
		lineageTag: 07c0a038-7183-4165-b55f-6ddfbf6589b3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Prix_Min = MIN(fact_equipement[price])
		lineageTag: 9057332b-ab7e-4d89-94f2-0a8d724b16af

		annotation PBI_FormatHint = {"isGeneralNumber":true}

