		lineageTag: e13b07ce-c08e-4eef-96de-92955ef9c240

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Nb_Lignes = COUNT(fact_equipement[Id_Fact])
		formatString: 0
		lineageTag: 9c24c62a-95cc-472c-91b2-1dbef44e7341

	measure Nb_Raquettes = COUNTROWS(RELATEDTABLE(fact_equipement))
		formatString: 0
		lineageTag: 795913ec-3215-4e68-ab1e-96dbb911c33c

